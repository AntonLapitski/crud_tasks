    public function buildCategoryTree(array &$elements, $parentId = null)
    {
        $branch = array();

        foreach ($elements as $element) {
            if ((string)$element['parent_id'] === (string)$parentId) {
                $children = $this->buildCategoryTree($elements, $element['id']);
                if ($children) {
                    $element['children'] = $children;
                }
                $branch[] = $element;
                unset($element);
            }
        }

        return $branch;
    }


    function group_by_city($data, $field) {
        $grouped_data = [];

        foreach ($data as $item) {
            $key = $item[$field];

            if (!isset($grouped_data[$key])) {
                $grouped_data[$key] = [];
            }

            $grouped_data[$key][] = $item;
        }

        return $grouped_data;
    }

    public function groupRecursive(array &$data, int $parentId = null): array {
        $grouped = [];
        foreach ($data as $item) {
            if ($item['parent_id'] == $parentId) {
                $new_item = $item;
                $children = $this->groupRecursive($data, $item['category_id']);
                if (!empty($children)) {
                    $new_item['children'] = $children;
                }
                $grouped[] = $new_item;
            }
        }
        return $grouped;
    }

    public function getParentsRecursive(array &$data, int $categoryId): array {
        $grouped = [];
        $i = 0;
        foreach ($data as $item ) {
            $i++;
            if($item['category_id'] == $categoryId  && $item['parent_id'] != null) {
                $grouped['parent_id'] = $item['parent_id'];
                $grouped['url'] = $item['url'];
                $par =  $this->getParentsRecursive($data, $item['parent_id']);
                if (!empty($par)){
                    $grouped[$i]['parent_id'] = $par;
                }
            }
        }
        return $grouped;
    }

